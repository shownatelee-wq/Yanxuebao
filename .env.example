# Shared
NODE_ENV=development

# API
PORT=3001
APP_URL=http://localhost:3001
JWT_ACCESS_SECRET=replace-with-access-secret
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
DATABASE_URL=postgresql://username:password@hostname:5432/yanxuebao_v1?schema=public

# Web apps
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
NEXT_PUBLIC_DEVICE_DATA_MODE=api
