{
  "name": "yanxuebao-v1",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "postinstall": "pnpm --filter @yanxuebao/config build && pnpm --filter @yanxuebao/types build && pnpm --filter @yanxuebao/ui build && pnpm --filter @yanxuebao/api prisma:generate",
    "dev": "turbo dev",
    "device": "pnpm --filter @yanxuebao/device-shell dev",
    "tutor": "pnpm --filter @yanxuebao/tutor-web exec next dev --port 3106",
    "tutor:build": "pnpm --filter @yanxuebao/tutor-web build",
    "dev:api": "pnpm --filter @yanxuebao/api dev",
    "dev:device": "pnpm --filter @yanxuebao/device-shell dev",
    "dev:device-demo": "concurrently -n API,DEVICE -c blue,green \"pnpm dev:api\" \"cross-env NEXT_PUBLIC_DEVICE_DATA_MODE=mock pnpm dev:device\"",
    "smoke:test": "node scripts/smoke-test.mjs",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.5.14",
    "@eslint/js": "^9.25.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1"
  }
}
